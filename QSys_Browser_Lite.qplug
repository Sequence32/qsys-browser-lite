    layout["Link_Go"] = { Style = "Button", Legend = "Go", Position = {W - 66, ly + 20}, Size = {58, 22},
      Color = {0, 120, 215}, OffColor = {30, 30, 30}, UnlinkOffColor = true, FontColor = {255, 255, 255} }

    -- Images

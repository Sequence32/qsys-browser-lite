  return layout, graphics
end

-- ============================================================================
-- RUNTIME
-- ============================================================================
if Controls then
  local rapidjson = require("rapidjson")

  local USER_AGENT = Properties["User Agent"].Value
  local TIMEOUT = Properties["Request Timeout"].Value
  local MAX_REDIRECTS = Properties["Max Redirects"].Value

  -- ==========================================
  -- URL Utilities
  -- ==========================================
  local function parse_url(url)
    local proto, host, port, path = url:match("^(https?)://([^:/]+):?(%d*)(.*)")
    if not proto then return nil end
    port = tonumber(port) or (proto == "https" and 443 or 80)
    if path == "" then path = "/" end
    return { protocol = proto, host = host, port = port, path = path, full = url }
  end

  local function resolve_url(base_url, relative)
    if not relative or relative == "" then return base_url end
    if relative:match("^https?://") then return relative end
    local parsed = parse_url(base_url)
    if not parsed then return relative end
    if relative:sub(1, 2) == "//" then
      return parsed.protocol .. ":" .. relative
    elseif relative:sub(1, 1) == "/" then
      return parsed.protocol .. "://" .. parsed.host .. (parsed.port ~= 80 and parsed.port ~= 443 and (":" .. parsed.port) or "") .. relative
    else
      local base_path = parsed.path:match("^(.*/)")  or "/"
      return parsed.protocol .. "://" .. parsed.host .. (parsed.port ~= 80 and parsed.port ~= 443 and (":" .. parsed.port) or "") .. base_path .. relative
    end
  end

  local function url_encode(str)
    if not str then return "" end
    return str:gsub("([^%w%-_%.~])", function(c) return string.format("%%%02X", string.byte(c)) end)
  end

  local function html_decode(str)
    if not str then return "" end
    local entities = { ["&amp;"] = "&", ["&lt;"] = "<", ["&gt;"] = ">", ["&quot;"] = '"', ["&#39;"] = "'", ["&nbsp;"] = " " }
    for ent, char in pairs(entities) do str = str:gsub(ent, char) end
    str = str:gsub("&#(%d+);", function(n)
      local num = tonumber(n)
      if num and num >= 0 and num <= 255 then return string.char(num) end
      return ""
    end)
    return str
  end

  -- ==========================================
  -- Cookie Manager
  -- ==========================================
  local cookies = {} -- { {name, value, domain, path, expires} }
  local COOKIE_FILE = "/tmp/browser_lite_cookies.json"

  local function save_cookies()
    local data = rapidjson.encode(cookies)
    Controls.Saved_Cookies.String = data or "[]"
    pcall(function()
      local f = io.open(COOKIE_FILE, "w")
      if f then f:write(data or "[]") f:close() end
    end)
  end

  local function load_cookies()
    local data = nil
    pcall(function()
      local f = io.open(COOKIE_FILE, "r")
      if f then data = f:read("*a") f:close() end
    end)
    if not data or data == "" then data = Controls.Saved_Cookies.String end
    if data and data ~= "" then
      local ok, result = pcall(rapidjson.decode, data)
      if ok and type(result) == "table" then cookies = result end
    end
  end

  local function parse_one_cookie(header_str, domain)
    if type(header_str) ~= "string" or header_str == "" then return end
    local name, value = header_str:match("^([^=]+)=([^;]*)")
    if not name then return end
    local cookie = { name = name:match("^%s*(.-)%s*$") or name, value = value or "", domain = domain, path = "/" }
    local d = header_str:match("[Dd]omain=([^;]+)")
    if d then cookie.domain = d:match("^%s*%.?(.-)%s*$") or d end
    local p = header_str:match("[Pp]ath=([^;]+)")
    if p then cookie.path = p:match("^%s*(.-)%s*$") or p end
    -- Replace existing cookie with same name+domain
    for i, c in ipairs(cookies) do
      if c.name == cookie.name and c.domain == cookie.domain then
        cookies[i] = cookie
        save_cookies()
        return
      end
    end
    table.insert(cookies, cookie)
    save_cookies()
  end

  local function parse_set_cookie(header, domain)
    if not header then return end
    if type(header) == "table" then
      for _, v in ipairs(header) do
        parse_one_cookie(v, domain)
      end
    else
      parse_one_cookie(header, domain)
    end
  end

  local function get_cookie_header(url)
    local parsed = parse_url(url)
    if not parsed then return nil end
    local parts = {}
    for _, c in ipairs(cookies) do
      if parsed.host:match(c.domain:gsub("%.", "%%.") .. "$") then
        if parsed.path:sub(1, #c.path) == c.path then
          table.insert(parts, c.name .. "=" .. c.value)
        end
      end
    end
    if #parts > 0 then return table.concat(parts, "; ") end
    return nil
  end

  local function update_cookie_display()
    local display = {}
    for _, c in ipairs(cookies) do
      table.insert(display, c.name .. "=" .. c.value:sub(1, 20) .. (c.value:len() > 20 and "..." or "") .. " (" .. c.domain .. ")")
    end
    Controls.Cookie_Jar.String = table.concat(display, "\n")
  end

  -- ==========================================
  -- HTML Parser
  -- ==========================================
  local function extract_title(html)
    return html_decode(html:match("<title[^>]*>(.-)</title>") or "")
  end

  local function extract_links(html, base_url)
    local links = {}
    local seen = {}
    for href in html:gmatch('<a[^>]+href=["\'](.-)["\']') do
      local full = resolve_url(base_url, html_decode(href))
      if not seen[full] and full:match("^https?://") then
        seen[full] = true
        -- Try to grab link text
        local pattern = 'href=["\']' .. href:gsub("([%(%)%.%%%+%-%*%?%[%]%^%$])", "%%%1") .. '["\'][^>]*>(.-)<'
        local text = html:match(pattern)
        text = text and text:gsub("<[^>]+>", ""):match("^%s*(.-)%s*$") or ""
        if text == "" then text = full end
        local label = text:sub(1, 60) .. (text:len() > 60 and "..." or "")
        table.insert(links, { url = full, label = label })
        if #links >= 50 then break end
      end
    end
    return links
  end

  local function extract_images_all(html, base_url)
    local images = {}
    local seen = {}

    local function add_image(url)
      if not url or url == "" then return end
      if url:match("^data:") then return end
      if url:sub(1, 2) == "//" then
        local p = parse_url(base_url)
        url = (p and p.protocol or "https") .. ":" .. url
      end
      local full = resolve_url(base_url, html_decode(url))
      if not seen[full] and full:match("^https?://") then
        if full:match("1x1") or full:match("pixel") or full:match("spacer") then return end
        seen[full] = true
        table.insert(images, full)
      end
    end

    -- 1. og:image
    for meta in html:gmatch("<meta([^>]+)>") do
      if meta:match('og:image') then
        local content = meta:match('content="([^"]+)"') or meta:match("content='([^']+)'")
        if content then add_image(content) end
      end
    end

    -- 2. img tags
    for tag in html:gmatch("<img([^>]+)>") do
      local src = tag:match('data%-src="([^"]+)"') or tag:match("data%-src='([^']+)'")
        or tag:match('data%-lazy%-src="([^"]+)"') or tag:match("data%-lazy%-src='([^']+)'")
      if not src then
        src = tag:match('src="([^"]+)"') or tag:match("src='([^']+)'")
      end
      if not src then
        local srcset = tag:match('srcset="([^"]+)"') or tag:match("srcset='([^']+)'")
        if srcset then src = srcset:match("([^%s,]+)") end
      end
      if src then add_image(src) end
      if #images >= 50 then break end
    end

    return images
  end

  -- Get filename from URL for display
  local function image_filename(url)
    if not url or url == "" then return "" end
    local name = url:match("([^/]+)$") or url
    name = name:match("^([^?#]+)") or name  -- strip query string
    if #name > 30 then name = "..." .. name:sub(-27) end
    return name
  end

  -- Image paging state
  local all_images = {}
  local image_offset = 0

  -- Content paging state
  local full_content = ""
  local content_offset = 0
  local CONTENT_PAGE_SIZE = 2000  -- chars per page

  -- Update 4 image slots from all_images at current offset
  local function update_image_display()
    local total = #all_images
    for i = 1, 4 do
      local idx = image_offset + i
      if idx <= total then
        local url = all_images[idx]
        Controls.Image_URL[i].String = url
        Controls.Image_Name[i].String = image_filename(url)
        Controls.Image_Display[i].String = '{"Protocol":"Image","URLs":["' .. url .. '"]}'
      else
        Controls.Image_URL[i].String = ""
        Controls.Image_Name[i].String = ""
        Controls.Image_Display[i].String = ""
      end
    end
    if total > 0 then
      local first = image_offset + 1
      local last = math.min(image_offset + 4, total)
      Controls.Image_Info.String = first .. "-" .. last .. " of " .. total
    else
      Controls.Image_Info.String = "No images"
    end
  end

  -- Update Page_Body with current content page
  local function update_content_display()
    local total_len = #full_content
    if total_len == 0 then
      Controls.Page_Body.String = ""
      Controls.Content_Info.String = ""
      return
    end
    local page_text = full_content:sub(content_offset + 1, content_offset + CONTENT_PAGE_SIZE)
    Controls.Page_Body.String = page_text
    local current_page = math.floor(content_offset / CONTENT_PAGE_SIZE) + 1
    local total_pages = math.ceil(total_len / CONTENT_PAGE_SIZE)
    Controls.Content_Info.String = "Page " .. current_page .. " / " .. total_pages
  end

  -- ==========================================
  -- Data Explorer Engine
  -- ==========================================
  local raw_response = ""
  local raw_offset = 0
  local RAW_PAGE_SIZE = 2000
  local parsed_json = nil  -- parsed JSON table for queries

  -- Wrap long lines for display in fixed-width text controls
  local function wrap_text(str, width)
    if not str then return "" end
    width = width or 80
    local result = {}
    for line in str:gmatch("([^\n]*)\n?") do
      if #line <= width then
        table.insert(result, line)
      else
        local pos = 1
        while pos <= #line do
          table.insert(result, line:sub(pos, pos + width - 1))
          pos = pos + width
        end
      end
    end
    return table.concat(result, "\n")
  end

  -- Update Raw_Data display with paging
  local function update_raw_display()
    local total_len = #raw_response
    if total_len == 0 then
      Controls.Raw_Data.String = ""
      Controls.Raw_Info.String = ""
      return
    end
    local page_text = raw_response:sub(raw_offset + 1, raw_offset + RAW_PAGE_SIZE)
    Controls.Raw_Data.String = page_text
    local current_page = math.floor(raw_offset / RAW_PAGE_SIZE) + 1
    local total_pages = math.ceil(total_len / RAW_PAGE_SIZE)
    Controls.Raw_Info.String = "Page " .. current_page .. " / " .. total_pages
  end

  -- Resolve a dot-notation path into a JSON table
  -- Supports: "key.subkey.0.field" (0-indexed arrays)
  local function json_path_resolve(tbl, path)
    if not tbl or not path or path == "" then return tbl end
    local current = tbl
    for segment in path:gmatch("[^%.]+") do
      if type(current) ~= "table" then return nil end
      -- Try as array index first (0-indexed)
      local idx = tonumber(segment)
      if idx ~= nil then
        current = current[idx + 1]  -- Lua is 1-indexed
      else
        current = current[segment]
      end
      if current == nil then return nil end
    end
    return current
  end

  -- Format a value for display
  local function format_json_value(val)
    if val == nil then return "(nil)" end
    if type(val) == "table" then
      local ok, str = pcall(rapidjson.encode, val, { pretty = true })
      if ok then return str end
      return "(table)"
    end
    return tostring(val)
  end

  -- Enumerate keys at a given path level
  local function enumerate_keys(tbl, path)
    local target = tbl
    if path and path ~= "" then
      target = json_path_resolve(tbl, path)
    end
    if type(target) ~= "table" then return {} end
    local keys = {}
    -- Check if it's an array (sequential numeric keys)
    local is_array = (#target > 0)
    if is_array then
      for i = 0, #target - 1 do
        local val = target[i + 1]
        local type_hint = type(val) == "table" and " {..}" or (" = " .. tostring(val):sub(1, 30))
        table.insert(keys, tostring(i) .. type_hint)
      end
    else
      for k, v in pairs(target) do
        local type_hint = type(v) == "table" and " {..}" or (" = " .. tostring(v):sub(1, 30))
        table.insert(keys, tostring(k) .. type_hint)
      end
      table.sort(keys)
    end
    return keys
  end

  -- Update the JSON_Keys dropdown for current path
  local function update_json_keys()
    if not parsed_json then
      Controls.JSON_Keys.Choices = {}
      return
    end
    local path = Controls.JSON_Path.String
    local keys = enumerate_keys(parsed_json, path)
    Controls.JSON_Keys.Choices = keys
  end


  local function extract_text(html)
    local text = html
    -- Remove script/style blocks
    text = text:gsub("<script[^>]*>.-</script>", "")
    text = text:gsub("<style[^>]*>.-</style>", "")
    text = text:gsub("<!--.->", "")
    -- Convert block elements to newlines
    text = text:gsub("<br[^>]*/?>", "\n")
    text = text:gsub("</?p[^>]*>", "\n")
    text = text:gsub("</?div[^>]*>", "\n")
    text = text:gsub("</?tr[^>]*>", "\n")
    text = text:gsub("</?li[^>]*>", "\n• ")
    text = text:gsub("</?h%d[^>]*>", "\n")
    text = text:gsub("<td[^>]*>", "\t")
    -- Strip remaining tags
    text = text:gsub("<[^>]+>", "")
    -- Decode entities
    text = html_decode(text)
    -- Collapse whitespace
    text = text:gsub("[ \t]+", " ")
    text = text:gsub("\n[ \t]+", "\n")
    text = text:gsub("[ \t]+\n", "\n")
    text = text:gsub("\n\n\n+", "\n\n")
    text = text:match("^%s*(.-)%s*$") or ""
    return text
  end

  local function extract_forms(html, base_url)
    local forms = {}
    for form_tag, form_body in html:gmatch("<form([^>]*)>(.-)</form>") do
      local action = form_tag:match('action=["\'](.-)["\']') or ""
      local method = (form_tag:match('method=["\'](.-)["\']') or "GET"):upper()
      action = resolve_url(base_url, html_decode(action))
      local fields = {}
      for input_tag in form_body:gmatch("<input([^>]*)>") do
        local name = input_tag:match('name=["\'](.-)["\']')
        local value = input_tag:match('value=["\'](.-)["\']') or ""
        local itype = (input_tag:match('type=["\'](.-)["\']') or "text"):lower()
        if name then table.insert(fields, { name = name, value = value, type = itype }) end
      end
      table.insert(forms, { action = action, method = method, fields = fields })
    end
    return forms
  end

  -- ==========================================
  -- History Manager
  -- ==========================================
  local history_back = {}
  local history_forward = {}
  local current_url = ""

  local function history_push(url)
    if current_url ~= "" then
      table.insert(history_back, current_url)
      if #history_back > 20 then table.remove(history_back, 1) end
    end
    history_forward = {}
    current_url = url
  end

  -- ==========================================
  -- State
  -- ==========================================
  local is_loading = false
  local current_links = {}
  local current_request = nil -- to allow cancellation

  -- ==========================================
  -- Auth Engine
  -- ==========================================
  local function build_auth_headers(headers)
    local auth_type = Controls.Auth_Type.String
    if auth_type == "Basic" then
      local user = Controls.Auth_Username.String
      local pass = Controls.Auth_Password.String
      if user ~= "" then
        local encoded = Crypto.Base64Encode(user .. ":" .. pass)
        headers["Authorization"] = "Basic " .. encoded
      end
    end
    return headers
  end

  local function do_form_login(callback)
    local login_url = Controls.Auth_Login_URL.String
    local user = Controls.Auth_Username.String
    local pass = Controls.Auth_Password.String
    if login_url == "" then
      print("[Browser] No login URL configured")
      return
    end
    local body = "username=" .. url_encode(user) .. "&password=" .. url_encode(pass)
    local headers = {
      ["Content-Type"] = "application/x-www-form-urlencoded",
      ["User-Agent"] = USER_AGENT
    }
    local cookie_h = get_cookie_header(login_url)
    if cookie_h then headers["Cookie"] = cookie_h end

    HttpClient.Upload({
      Url = login_url, Method = "POST", Headers = headers, Data = body, Timeout = TIMEOUT,
      EventHandler = function(tbl, code, data, err, hdrs)
        if hdrs then
          local parsed = parse_url(login_url)
          local domain = parsed and parsed.host or ""
          -- Handle multiple Set-Cookie headers
          if type(hdrs["Set-Cookie"]) == "string" then
            parse_set_cookie(hdrs["Set-Cookie"], domain)
          elseif type(hdrs["set-cookie"]) == "string" then
            parse_set_cookie(hdrs["set-cookie"], domain)
          end
        end
        update_cookie_display()
        if code and (code >= 200 and code < 400) then
          Controls.Auth_Status.Value = 1
          print("[Browser] Form login successful (HTTP " .. tostring(code) .. ")")
        else
          Controls.Auth_Status.Value = 2
          print("[Browser] Form login failed: " .. tostring(code) .. " " .. tostring(err))
        end
        if callback then callback(code) end
      end
    })
  end

  -- ==========================================
  -- HTTP Engine
  -- ==========================================
  local navigate -- forward declaration

  -- Helper: header values can be string or table (multiple values from server)
  local function hdr_to_str(v)
    if type(v) == "table" then return table.concat(v, ", ") end
    return tostring(v or "")
  end

  local function http_request(url, method, body, headers, redirect_count, callback)
    if not url or url == "" then return end
    redirect_count = redirect_count or 0
    method = method or "GET"

    local parsed = parse_url(url)
    if not parsed then
      Controls.Status_Text.String = "Invalid URL"
      Controls.Loading.Value = 0
      is_loading = false
      return
    end

    -- Build headers
    headers = headers or {}
    headers["User-Agent"] = headers["User-Agent"] or USER_AGENT
    headers = build_auth_headers(headers)
    local cookie_h = get_cookie_header(url)
    if cookie_h then headers["Cookie"] = cookie_h end

    is_loading = true
    Controls.Loading.Value = 1
    Controls.Status_Text.String = method .. " " .. url
    print("[Browser] HTTP " .. method .. " " .. url)

    local handler = function(tbl, code, data, err, resp_hdrs)
      print("[Browser] Response: code=" .. tostring(code) .. " err=" .. tostring(err) .. " dataLen=" .. tostring(data and #data or 0))

      -- Process cookies from response
      if resp_hdrs then
        for k, v in pairs(resp_hdrs) do
          if type(k) == "string" and k:lower() == "set-cookie" then
            parse_set_cookie(v, parsed.host)
          end
        end
        update_cookie_display()
      end

      -- Handle errors
      if err and (not code or code == 0) then
        Controls.Loading.Value = 0
        is_loading = false
        Controls.Status_Code.String = "ERR"
        Controls.Status_Text.String = "Error: " .. tostring(err)
        Controls.Page_Body.String = "Request failed: " .. tostring(err) .. "\n\nURL: " .. url
        print("[Browser] Request failed: " .. tostring(err))
        return
      end

      -- Handle redirects
      if code and (code == 301 or code == 302 or code == 303 or code == 307 or code == 308) then
        if redirect_count >= MAX_REDIRECTS then
          Controls.Status_Text.String = "Too many redirects"
          Controls.Loading.Value = 0
          is_loading = false
          return
        end
        local location = nil
        if resp_hdrs then
          for k, v in pairs(resp_hdrs) do
            if type(k) == "string" and k:lower() == "location" then
              location = hdr_to_str(v)
              break
            end
          end
        end
        if location then
          location = resolve_url(url, location)
          print("[Browser] Redirect -> " .. location)
          Controls.Status_Text.String = "Redirect -> " .. location
          local new_method = method
          if code == 303 then new_method = "GET" end
          http_request(location, new_method, (code == 307 or code == 308) and body or nil, headers, redirect_count + 1, callback)
          return
        end
      end



      Controls.Loading.Value = 0
      is_loading = false
      Controls.Status_Code.String = tostring(code or "ERR")

      -- Extract content type
      local content_type = ""
      if resp_hdrs then
        for k, v in pairs(resp_hdrs) do
          if type(k) == "string" and k:lower() == "content-type" then content_type = hdr_to_str(v) break end
        end
      end
      Controls.Content_Type.String = content_type

      -- Display response headers
      if resp_hdrs then
        local hdr_lines = {}
        for k, v in pairs(resp_hdrs) do
          table.insert(hdr_lines, tostring(k) .. ": " .. hdr_to_str(v))
        end
        Controls.Response_Headers.String = table.concat(hdr_lines, "\n")
      end

      if callback then callback(code, data, resp_hdrs, url) end
    end

    local ok, request_err = pcall(function()
      if method == "GET" then
        HttpClient.Download({ Url = url, Headers = headers, Timeout = TIMEOUT, EventHandler = handler })
      else
        HttpClient.Upload({ Url = url, Method = method, Headers = headers, Data = body or "", Timeout = TIMEOUT, EventHandler = handler })
      end
    end)
    if not ok then
      Controls.Loading.Value = 0
      is_loading = false
      Controls.Status_Code.String = "ERR"
      Controls.Status_Text.String = "HttpClient error: " .. tostring(request_err)
      Controls.Page_Body.String = "Failed to send request: " .. tostring(request_err)
      print("[Browser] HttpClient error: " .. tostring(request_err))
    end
  end

  -- ==========================================
  -- Display Engine
  -- ==========================================
  local function display_page(code, data, hdrs, final_url)
    if not data then
      Controls.Status_Text.String = "No data received"
      return
    end

    Controls.URL_Bar.String = final_url or current_url
    current_url = final_url or current_url

    -- Store raw response for Data Explorer
    -- Clean data: strip UTF-8 BOM and trim whitespace
    local clean_data = data or ""
    -- Strip UTF-8 BOM (EF BB BF)
    if clean_data:sub(1, 3) == "\xEF\xBB\xBF" then
      clean_data = clean_data:sub(4)
    end
    clean_data = clean_data:match("^%s*(.-)%s*$") or clean_data

    -- Pretty-print JSON for readability, wrap other content
    local raw_ok, raw_parsed = pcall(rapidjson.decode, clean_data)
    if raw_ok and raw_parsed ~= nil then
      local pretty_ok, pretty_str = pcall(rapidjson.encode, raw_parsed, { pretty = true })
      if pretty_ok and pretty_str then
        raw_response = pretty_str
      else
        raw_response = wrap_text(clean_data, 80)
      end
    else
      raw_response = wrap_text(clean_data, 80)
    end
    raw_offset = 0
    update_raw_display()

    -- Try to parse as JSON for query engine
    parsed_json = nil
    Controls.JSON_Path.String = ""
    Controls.JSON_Result.String = ""
    if raw_ok and raw_parsed ~= nil then
      if type(raw_parsed) == "table" then
        parsed_json = raw_parsed
        print("[Browser] JSON parsed OK - " .. tostring(#clean_data) .. " bytes")
      else
        -- JSON returned a primitive (string, number, bool) - wrap it
        parsed_json = { value = raw_parsed }
        print("[Browser] JSON parsed as primitive: " .. type(raw_parsed))
      end
    else
      -- Log first bytes for debugging
      local first_bytes = ""
      for i = 1, math.min(10, #clean_data) do
        first_bytes = first_bytes .. string.format("%02X ", clean_data:byte(i))
      end
      print("[Browser] JSON parse failed: " .. tostring(raw_parsed) .. " | first bytes: " .. first_bytes .. " | preview: " .. clean_data:sub(1, 60))
    end
    update_json_keys()

    local ct = Controls.Content_Type.String:lower()

    if ct:match("json") then
      Controls.Page_Title.String = "[JSON Response]"
      if parsed_json then
        full_content = rapidjson.encode(parsed_json, { pretty = true }) or data
      else
        full_content = data
      end
      content_offset = 0
      update_content_display()
      Controls.Link_List.Choices = {}
      current_links = {}
      all_images = {}
      image_offset = 0
      update_image_display()

    elseif ct:match("html") or ct == "" then
      -- Parse HTML
      Controls.Page_Title.String = extract_title(data)
      full_content = extract_text(data)
      content_offset = 0
      update_content_display()

      -- Extract links
      current_links = extract_links(data, current_url)
      local choices = {}
      for _, link in ipairs(current_links) do
        table.insert(choices, link.label)
      end
      Controls.Link_List.Choices = choices

      -- Extract images and display first page
      all_images = extract_images_all(data, current_url)
      image_offset = 0
      update_image_display()

    else
      -- Plain text or other
      Controls.Page_Title.String = "[" .. Controls.Content_Type.String .. "]"
      full_content = data
      content_offset = 0
      update_content_display()
      Controls.Link_List.Choices = {}
      current_links = {}
      all_images = {}
      image_offset = 0
      update_image_display()
    end

    Controls.Status_Text.String = "Done - " .. tostring(code)
    print("[Browser] Loaded: " .. current_url)
  end

  -- ==========================================
  -- Navigate Function
  -- ==========================================
  navigate = function(url, push_history)
    if not url or url == "" then
      print("[Browser] Navigate called with empty URL")
      return
    end
    -- Auto-prepend https://
    if not url:match("^https?://") then url = "https://" .. url end
    if push_history ~= false then history_push(url) end
    Controls.URL_Bar.String = url
    print("[Browser] Navigating to: " .. url)

    local method = Controls.Request_Method.String
    if method == "" then method = "GET" end
    local body = nil
    if method ~= "GET" then body = Controls.Request_Body.String end

    -- Parse custom headers
    local custom_headers = {}
    local hdr_str = Controls.Request_Headers.String
    if hdr_str and hdr_str ~= "" then
      local ok, parsed = pcall(rapidjson.decode, hdr_str)
      if ok and type(parsed) == "table" then custom_headers = parsed end
    end

    http_request(url, method, body, custom_headers, 0, display_page)
  end

  -- ==========================================
  -- Control Event Handlers
  -- ==========================================
  Controls.Go.EventHandler = function()
    navigate(Controls.URL_Bar.String)
  end

  Controls.URL_Bar.EventHandler = function()
    navigate(Controls.URL_Bar.String)
  end

  Controls.Back.EventHandler = function()
    if #history_back > 0 then
      table.insert(history_forward, current_url)
      local url = table.remove(history_back)
      current_url = ""
      navigate(url, false)
    end
  end

  Controls.Forward.EventHandler = function()
    if #history_forward > 0 then
      table.insert(history_back, current_url)
      local url = table.remove(history_forward)
      current_url = ""
      navigate(url, false)
    end
  end

  Controls.Refresh.EventHandler = function()
    if current_url ~= "" then
      navigate(current_url, false)
    end
  end

  Controls.Stop.EventHandler = function()
    Controls.Loading.Value = 0
    is_loading = false
    Controls.Status_Text.String = "Stopped"
  end

  Controls.Link_Go.EventHandler = function()
    local selected = Controls.Link_List.String
    for _, link in ipairs(current_links) do
      if link.label == selected then
        navigate(link.url)
        break
      end
    end
  end

  Controls.Image_Prev.EventHandler = function()
    if image_offset >= 4 then
      image_offset = image_offset - 4
      update_image_display()
    end
  end

  Controls.Image_Next.EventHandler = function()
    if image_offset + 4 < #all_images then
      image_offset = image_offset + 4
      update_image_display()
    end
  end

  Controls.Content_Prev.EventHandler = function()
    if content_offset >= CONTENT_PAGE_SIZE then
      content_offset = content_offset - CONTENT_PAGE_SIZE
      update_content_display()
    end
  end

  Controls.Content_Next.EventHandler = function()
    if content_offset + CONTENT_PAGE_SIZE < #full_content then
      content_offset = content_offset + CONTENT_PAGE_SIZE
      update_content_display()
    end
  end

  -- Data Explorer handlers
  Controls.Raw_Prev.EventHandler = function()
    if raw_offset >= RAW_PAGE_SIZE then
      raw_offset = raw_offset - RAW_PAGE_SIZE
      update_raw_display()
    end
  end

  Controls.Raw_Next.EventHandler = function()
    if raw_offset + RAW_PAGE_SIZE < #raw_response then
      raw_offset = raw_offset + RAW_PAGE_SIZE
      update_raw_display()
    end
  end

  Controls.JSON_Query.EventHandler = function()
    if not parsed_json then
      Controls.JSON_Result.String = "No JSON data loaded. Navigate to a URL that returns JSON."
      return
    end
    local path = Controls.JSON_Path.String
    local result = json_path_resolve(parsed_json, path)
    Controls.JSON_Result.String = format_json_value(result)
    update_json_keys()
    print("[Browser] JSON Query: " .. (path ~= "" and path or "(root)") .. " -> " .. type(result))
  end

  Controls.JSON_Drill.EventHandler = function()
    if not parsed_json then return end
    local selected = Controls.JSON_Keys.String
    if not selected or selected == "" then return end
    -- Extract just the key name (before the type hint)
    local key = selected:match("^(%S+)") or selected
    -- Strip value previews: "keyname = value" or "keyname {..}"
    key = key:match("^([^%s]+)") or key
    local current_path = Controls.JSON_Path.String
    if current_path ~= "" then
      Controls.JSON_Path.String = current_path .. "." .. key
    else
      Controls.JSON_Path.String = key
    end
    -- Auto-query on drill
    local result = json_path_resolve(parsed_json, Controls.JSON_Path.String)
    Controls.JSON_Result.String = format_json_value(result)
    update_json_keys()
    print("[Browser] Drilled into: " .. Controls.JSON_Path.String)
  end

  Controls.Clear_Cookies.EventHandler = function()
    cookies = {}
    save_cookies()
    update_cookie_display()
    Controls.Auth_Status.Value = 0
    print("[Browser] Cookies cleared")
  end

  -- Init dropdowns
  Controls.Auth_Type.Choices = { "None", "Basic", "Form" }
  Controls.Auth_Type.String = "None"
  Controls.Request_Method.Choices = { "GET", "POST", "PUT", "DELETE", "PATCH" }
  Controls.Request_Method.String = "GET"

  -- Auth type handler
  Controls.Auth_Type.EventHandler = function(ctrl)
    if ctrl.String == "Form" then
      print("[Browser] Form auth selected. Configure login URL, username, password, then navigate.")
    elseif ctrl.String == "Basic" then
      print("[Browser] Basic auth selected. Credentials will be sent with every request.")
      Controls.Auth_Status.Value = 1
    else
      Controls.Auth_Status.Value = 0
    end
  end

  -- Form login triggered when Auth_Login_URL changes and type is Form
  Controls.Auth_Login_URL.EventHandler = function()
    if Controls.Auth_Type.String == "Form" and Controls.Auth_Login_URL.String ~= "" then
      do_form_login()
    end
  end

  -- Load saved cookies on init
  load_cookies()
  update_cookie_display()
  Controls.Loading.Value = 0
  Controls.Status_Text.String = "Ready"
  print("[Browser Lite] Plugin initialized. Enter a URL and press Go.")
end

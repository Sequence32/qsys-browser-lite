    { Name = "Auth_Username", ControlType = "Text", Count = 1, PinStyle = "Input", UserPin = true },
    { Name = "Auth_Password", ControlType = "Text", Count = 1, PinStyle = "Input", UserPin = true },
    { Name = "Auth_Login_URL", ControlType = "Text", Count = 1, PinStyle = "Input", UserPin = true },
    { Name = "Auth_Status", ControlType = "Indicator", IndicatorType = "LED", Count = 1, PinStyle = "Output", UserPin = true },

    -- Cookies
    { Name = "Cookie_Jar", ControlType = "Text", Count = 1, PinStyle = "Output", UserPin = true },
    { Name = "Clear_Cookies", ControlType = "Button", ButtonType = "Trigger", Count = 1, PinStyle = "Input", UserPin = true },

    -- Persistence
    { Name = "Saved_Cookies", ControlType = "Text", Count = 1, PinStyle = "None", UserPin = false },

    -- Data Explorer
    { Name = "Raw_Data", ControlType = "Text", Count = 1, PinStyle = "Output", UserPin = true },
    { Name = "Raw_Prev", ControlType = "Button", ButtonType = "Trigger", Count = 1, PinStyle = "Input", UserPin = true },
    { Name = "Raw_Next", ControlType = "Button", ButtonType = "Trigger", Count = 1, PinStyle = "Input", UserPin = true },
    { Name = "Raw_Info", ControlType = "Text", Count = 1, PinStyle = "Output", UserPin = true },
    { Name = "JSON_Path", ControlType = "Text", Count = 1, PinStyle = "Both", UserPin = true },

    Color = {60, 60, 60}, OffColor = {35, 35, 35}, UnlinkOffColor = true, FontColor = {255, 255, 255} }
  layout["Forward"] = { Style = "Button", Legend = ">", Position = {40, 42}, Size = {28, 28},
    Color = {60, 60, 60}, OffColor = {35, 35, 35}, UnlinkOffColor = true, FontColor = {255, 255, 255} }
  layout["Refresh"] = { Style = "Button", Legend = "R", Position = {72, 42}, Size = {28, 28},
    Color = {60, 60, 60}, OffColor = {35, 35, 35}, UnlinkOffColor = true, FontColor = {255, 255, 255} }
  layout["URL_Bar"] = { Style = "Text", Position = {104, 42}, Size = {330, 28} }
  layout["Go"] = { Style = "Button", Legend = "GO", Position = {438, 42}, Size = {50, 28},
    Color = {0, 120, 215}, OffColor = {30, 30, 30}, UnlinkOffColor = true, FontColor = {255, 255, 255} }
  layout["Loading"] = { Style = "Indicator", Position = {W - 18, 27}, Size = {14, 14}, Color = {0, 200, 100}, OffColor = {50, 50, 50}, UnlinkOffColor = true }

  -- Status bar (all pages)
  table.insert(graphics, { Type = "GroupBox", Text = "Status", Position = {0, 90}, Size = {W, 40} })
  table.insert(graphics, { Type = "Label", Text = "Code:", Position = {5, 103}, Size = {35, 20}, HTextAlign = "Right", Color = {150, 150, 150} })
  layout["Status_Code"] = { Style = "Text", Position = {44, 103}, Size = {40, 20} }
  table.insert(graphics, { Type = "Label", Text = "Type:", Position = {88, 103}, Size = {35, 20}, HTextAlign = "Right", Color = {150, 150, 150} })
  layout["Content_Type"] = { Style = "Text", Position = {127, 103}, Size = {130, 20} }
  table.insert(graphics, { Type = "Label", Text = "Title:", Position = {261, 103}, Size = {35, 20}, HTextAlign = "Right", Color = {150, 150, 150} })
  layout["Page_Title"] = { Style = "Text", Position = {300, 103}, Size = {192, 20} }

  if page == 1 then
    -- ========== PAGE 1: BROWSER ==========
    local y = 135

    -- Content area
    table.insert(graphics, { Type = "GroupBox", Text = "Page Content", Position = {0, y}, Size = {W, 220}, Color = {30, 30, 30} })
    -- Paging controls

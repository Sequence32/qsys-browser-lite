    layout["JSON_Path"] = { Style = "Text", Position = {48, qy + 20}, Size = {W - 130, 22} }
    layout["JSON_Query"] = { Style = "Button", Legend = "Query", Position = {W - 74, qy + 20}, Size = {58, 22},
      Color = {0, 120, 215}, OffColor = {30, 30, 30}, UnlinkOffColor = true, FontColor = {255, 255, 255} }
    table.insert(graphics, { Type = "Label", Text = "Result:", Position = {8, qy + 48}, Size = {35, 22}, HTextAlign = "Right", Color = {150, 150, 150} })

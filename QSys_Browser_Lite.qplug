    layout["Clear_Cookies"] = { Style = "Button", Legend = "Clear", Position = {W - 78, cy}, Size = {60, 22},
      Color = {180, 50, 50}, OffColor = {60, 60, 60}, UnlinkOffColor = true, FontColor = {255, 255, 255} }

  elseif page == 3 then
    -- ========== PAGE 3: REQUEST ==========
    local y = 135
    table.insert(graphics, { Type = "GroupBox", Text = "Request", Position = {0, y}, Size = {W, 120}, Color = {30, 30, 30} })

    table.insert(graphics, { Type = "Label", Text = "Method:", Position = {8, y + 20}, Size = {55, 22}, HTextAlign = "Right", Color = {150, 150, 150} })

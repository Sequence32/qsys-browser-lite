-- Plugin Info
PluginInfo = {
  Name = "Browser Lite",
  Version = "0.2.0.003",
  BuildVersion = "1.0.0.0",
  Id = "dstn.qsys.browser-lite",
  Author = "Dustin Bennett",
  Description = "Lightweight HTTP browser for Q-SYS with auth, navigation, and image display."
}

function GetColor() return { 0, 120, 215 } end
function GetPrettyName() return "Browser Lite" end

function GetProperties()
  return {
    { Name = "User Agent", Type = "string", Value = "QSys-Browser-Lite/0.1" },
    { Name = "Request Timeout", Type = "integer", Value = 10, Min = 1, Max = 60 },
    { Name = "Max Redirects", Type = "integer", Value = 5, Min = 0, Max = 10 },
    { Name = "Core IP Address", Type = "string", Value = "" }
  }
end

function GetControls()
  return {
    -- Navigation
    { Name = "URL_Bar", ControlType = "Text", Count = 1, PinStyle = "Both", UserPin = true },
    { Name = "Go", ControlType = "Button", ButtonType = "Trigger", Count = 1, PinStyle = "Input", UserPin = true },
    { Name = "Back", ControlType = "Button", ButtonType = "Trigger", Count = 1, PinStyle = "Input", UserPin = true },
    { Name = "Forward", ControlType = "Button", ButtonType = "Trigger", Count = 1, PinStyle = "Input", UserPin = true },
    { Name = "Refresh", ControlType = "Button", ButtonType = "Trigger", Count = 1, PinStyle = "Input", UserPin = true },
    { Name = "Stop", ControlType = "Button", ButtonType = "Trigger", Count = 1, PinStyle = "Input", UserPin = true },

    -- Status
    { Name = "Status_Code", ControlType = "Text", Count = 1, PinStyle = "Output", UserPin = true },
    { Name = "Status_Text", ControlType = "Text", Count = 1, PinStyle = "Output", UserPin = true },
    { Name = "Content_Type", ControlType = "Text", Count = 1, PinStyle = "Output", UserPin = true },
    { Name = "Page_Title", ControlType = "Text", Count = 1, PinStyle = "Output", UserPin = true },
    { Name = "Loading", ControlType = "Indicator", IndicatorType = "LED", Count = 1, PinStyle = "Output", UserPin = true },

    -- Content Display
    { Name = "Page_Body", ControlType = "Text", Count = 1, PinStyle = "Output", UserPin = true },
    { Name = "Content_Prev", ControlType = "Button", ButtonType = "Trigger", Count = 1, PinStyle = "Input", UserPin = true },
    { Name = "Content_Next", ControlType = "Button", ButtonType = "Trigger", Count = 1, PinStyle = "Input", UserPin = true },
    { Name = "Content_Info", ControlType = "Text", Count = 1, PinStyle = "Output", UserPin = true },
    { Name = "Link_List", ControlType = "Text", Count = 1, PinStyle = "Both", UserPin = true },
    { Name = "Link_Go", ControlType = "Button", ButtonType = "Trigger", Count = 1, PinStyle = "Input", UserPin = true },
    { Name = "Image_Display", ControlType = "Text", Count = 4, PinStyle = "Output", UserPin = true },
    { Name = "Image_URL", ControlType = "Text", Count = 4, PinStyle = "Output", UserPin = true },
    { Name = "Image_Name", ControlType = "Text", Count = 4, PinStyle = "Output", UserPin = true },
    { Name = "Image_Prev", ControlType = "Button", ButtonType = "Trigger", Count = 1, PinStyle = "Input", UserPin = true },
    { Name = "Image_Next", ControlType = "Button", ButtonType = "Trigger", Count = 1, PinStyle = "Input", UserPin = true },

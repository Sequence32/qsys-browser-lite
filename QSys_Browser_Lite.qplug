    { Name = "JSON_Keys", ControlType = "Text", Count = 1, PinStyle = "Both", UserPin = true },
    { Name = "JSON_Drill", ControlType = "Button", ButtonType = "Trigger", Count = 1, PinStyle = "Input", UserPin = true }
  }
end

function GetPages(props)
  return {
    { name = "Browser" },
    { name = "Auth" },
    { name = "Request" },
    { name = "Data" }
  }
end

function GetControlLayout(props)
